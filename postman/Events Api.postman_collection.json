{
  "info": {
    "_postman_id": "events-api-collection",
    "name": "Events Api",
    "description": "Colección de requests para el microservicio events — deber AE 2026",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080",
      "type": "string"
    },
    {
      "key": "accessToken",
      "value": "",
      "type": "string",
      "description": "Pega aquí el access_token obtenido desde Postman OAuth 2.0"
    }
  ],
  "item": [
    {
      "name": "Events (Público)",
      "item": [
        {
          "name": "GET /api/events — cartelera pública (sin token)",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/events",
            "description": "Endpoint público. No requiere token. Devuelve la lista de todos los eventos."
          }
        },
        {
          "name": "GET /api/events/{id} — detalle de evento (sin token)",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/events/1",
            "description": "Endpoint público. No requiere token. Devuelve el detalle de un evento."
          }
        }
      ]
    },
    {
      "name": "Events (Privado)",
      "item": [
        {
          "name": "POST /api/events — crear evento (con token)",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/events",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Rock Fest 2026\",\n  \"venue\": \"Estadio Olímpico Atahualpa\",\n  \"totalTickets\": 500\n}"
            },
            "description": "Privado. Requiere Bearer token de Cognito."
          }
        }
      ]
    },
    {
      "name": "Attendees (Privado)",
      "item": [
        {
          "name": "POST /api/attendees — crear asistente (con token)",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/attendees",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Bryan Taco\",\n  \"email\": \"btaco@puce.edu.ec\"\n}"
            },
            "description": "Privado. Requiere Bearer token de Cognito."
          }
        },
        {
          "name": "GET /api/attendees — listar asistentes (con token)",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/attendees",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ]
          }
        }
      ]
    },
    {
      "name": "Reservations (Privado)",
      "item": [
        {
          "name": "POST /api/reservations — reservar entrada (con token)",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/reservations",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"attendeeId\": 1,\n  \"eventId\": 1\n}"
            },
            "description": "Privado. Requiere Bearer token de Cognito."
          }
        },
        {
          "name": "POST /api/reservations — sin token → 401",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/reservations",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"attendeeId\": 1,\n  \"eventId\": 1\n}"
            },
            "description": "Sin token. Debe responder 401 Unauthorized."
          }
        },
        {
          "name": "PUT /api/reservations/{id}/cancel — cancelar (con token)",
          "request": {
            "method": "PUT",
            "url": "{{baseUrl}}/api/reservations/1/cancel",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "description": "Privado. Requiere Bearer token de Cognito."
          }
        },
        {
          "name": "GET /api/reservations — listar reservas (con token)",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/reservations",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ]
          }
        }
      ]
    }
  ],
  "auth": {
    "type": "oauth2",
    "oauth2": [
      {
        "key": "tokenName",
        "value": "Cognito Access Token",
        "type": "string"
      },
      {
        "key": "grant_type",
        "value": "authorization_code",
        "type": "string"
      },
      {
        "key": "callbackURL",
        "value": "https://oauth.pstmn.io/v1/callback",
        "type": "string"
      },
      {
        "key": "scope",
        "value": "openid email profile",
        "type": "string"
      },
      {
        "key": "addTokenTo",
        "value": "header",
        "type": "string"
      }
    ]
  }
}
